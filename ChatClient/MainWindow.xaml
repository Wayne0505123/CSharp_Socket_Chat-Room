<Window x:Class="ChatClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chat Client" Height="450" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 連線設定區 -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <TextBox x:Name="txtIP" Width="150" Text="127.0.0.1" Margin="0,0,10,0"/>
            <TextBox x:Name="txtPort" Width="80" Text="8888" Margin="0,0,10,0"/>
            <TextBox x:Name="txtUsername" Width="100" Text="user01" Margin="0,0,10,0"/>
            <Button x:Name="btnConnect" Content="Connect" Width="100" Click="btnConnect_Click"/>
            <Button x:Name="btnDisconnect" Content="Disconnect" Width="100" Click="btnDisconnect_Click" IsEnabled="False"/>
            <TextBlock x:Name="txtStatus" VerticalAlignment="Center" Margin="10,0,0,0" Text="Disconnected"/>
        </StackPanel>

        <!-- 訊息紀錄區 -->
        <TextBox x:Name="txtMessages" Grid.Row="1" IsReadOnly="True"
                 TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>

        <!-- 發送訊息區 -->
        <StackPanel Orientation="Horizontal" Grid.Row="2" Margin="0,10,0,0">
            <TextBox x:Name="txtInput" Width="600" Height="30" Margin="0,0,10,0"/>
            <Button Content="Send" Width="80" Click="btnSend_Click"/>
        </StackPanel>
    </Grid>
</Window>
