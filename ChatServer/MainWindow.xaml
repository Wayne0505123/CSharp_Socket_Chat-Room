<Window x:Class="ChatServer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chat Server" Height="450" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>


        <!-- Start/Stop Button + Server Info -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <TextBox x:Name="txtServerIP" Width="120" Text="127.0.0.1" Margin="0,0,10,0"/>
            <TextBox x:Name="txtServerPort" Width="60" Text="8888" Margin="0,0,10,0"/>
            <Button x:Name="btnStart" Content="Start Listening" Width="120" Margin="0,0,10,0" Click="btnStart_Click"/>
            <Button x:Name="btnStop" Content="Stop" Width="80" IsEnabled="False" Click="btnStop_Click"/>
            <TextBlock x:Name="txtStatus" Text="Server not running" VerticalAlignment="Center" Margin="20,0,0,0"/>
        </StackPanel>


        <!-- Chat Logs + Connected Clients -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Message Logs -->
            <TextBox x:Name="txtMessages" Grid.Column="0" 
                     IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                     TextWrapping="Wrap" AcceptsReturn="True"/>

            <!-- Connected Clients -->
            <ListBox x:Name="listClients" Grid.Column="1" Margin="10,0,0,0"/>
        </Grid>

        <!-- Manual Message Sender -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
            <TextBox x:Name="txtBroadcast" Width="600" Height="30" Margin="0,0,10,0"/>
            <Button Content="Send" Width="80" Click="btnSend_Click"/>
        </StackPanel>
    </Grid>
</Window>
